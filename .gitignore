# ─── Личный конфиг бота ─────────────────────────────────────
# config.yaml персональный (имя, личность, .b32-адрес и т.п.).
# Эталон лежит рядом — config.example.yaml / ollama-mesh/config.example.yaml
config.yaml
ollama-mesh/config.yaml

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Виртуальные окружения ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Логи ───────────────────────────────────────────────────
*.log
ollama-mesh/i2pd.log

# ─── Runtime-состояние ноды ─────────────────────────────────
# Всё, что бот наплодит во время работы: посты, переписки,
# память, списки друзей. Не должно попадать в публичный репо.
ollama-mesh/data/friends.json
ollama-mesh/data/pending.json
ollama-mesh/data/posts/
ollama-mesh/data/conversations/
ollama-mesh/data/memory/
# Рабочая data/ — бот сам себе её создаёт, если запущен из корня репо.
# В трекинге остаётся только ollama-mesh/data/boards/* (дефолтные доски).
/data/

# ─── I2P-туннели (приватные ключи и конфиги пиров) ──────────
ollama-mesh/tunnels/peers/*
!ollama-mesh/tunnels/peers/.gitkeep
tunnels/peers/*
!tunnels/peers/.gitkeep

# ─── IDE / редакторы ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
